{
  "cli": {
    "version": ">= 7.8.5",
    "appVersionSource": "remote"
  },
  "build": {
    "android_development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "ios_simulator_development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      }
    },
    "ios_device_development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": false
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "development",
      "environment": "development"
    },
    "staging": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "staging",
      "environment": "development"
    },
    "production-testflight": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "production-testflight",
      "environment": "production"
    }
  },
  "submit": {
    "staging": {
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "completed"
      }
    },
    "production-testflight": {
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "completed"
      }
    }
  }
}
